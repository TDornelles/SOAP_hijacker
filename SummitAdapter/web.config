<?xml version="1.0" encoding="utf-8"?>
<!--
  Checked-in web.config so IIS hosting is reproducible. `dotnet publish` runs the web.config
  transform and fills in the correct processPath/arguments for the published output.

  - hostingModel="inprocess" — in-process hosting under a "No Managed Code" app pool (spec section 10).
  - stdoutLogEnabled is OFF by default. For first-cutover diagnosis flip it to "true", recycle the
    app pool, reproduce, read .\logs\stdout_*.log, then set it back to "false".
  - Non-secret config (GLP/legacy URLs and paths) lives in appsettings.Production.json — the single
    source of truth, loaded via ASPNETCORE_ENVIRONMENT=Production. Only secrets go here, as
    environment variables filled in on the server (never committed).
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore name="aspNetCore"
                  processPath=".\SummitAdapter.exe"
                  arguments=""
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <!-- Ship endpoint API key (Rate is public and needs none). SECRET: fill this in on the
               SERVER after pulling — do not commit a real key. Without it, Ship calls fail fast.
          <environmentVariable name="Glp__ApiKey" value="PUT-THE-KEY-HERE-ON-THE-SERVER" /> -->
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
