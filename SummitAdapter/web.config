<?xml version="1.0" encoding="utf-8"?>
<!--
  Checked-in web.config so IIS hosting is reproducible. `dotnet publish` runs the web.config
  transform and fills in the correct processPath/arguments for the published output.

  - hostingModel="inprocess" — in-process hosting under a "No Managed Code" app pool (spec section 10).
  - stdoutLogEnabled is OFF by default. For first-cutover diagnosis flip it to "true", recycle the
    app pool, reproduce, read .\logs\stdout_*.log, then set it back to "false".
  - Non-secret config (the GLP base URL) is supplied here as an environment variable; it can also be
    set in appsettings.Production.json. ASPNETCORE_ENVIRONMENT=Production loads that file.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore name="aspNetCore"
                  processPath=".\SummitAdapter.exe"
                  arguments=""
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <!-- Override the GLP target without editing appsettings; remove if set in appsettings.Production.json. -->
          <environmentVariable name="Glp__BaseUrl" value="http://glp.internal:8080" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
